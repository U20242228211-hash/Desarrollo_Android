<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 1. Encabezado superior -->
        <TextView
            android:id="@+id/textoTituloApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenido a SeMeOlvidaNo"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121" />

        <TextView
            android:id="@+id/textoSubtituloApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Organiza tu día de forma simple"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="24dp" />

        <!-- 2. Sección: Pendientes de hoy -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pendientes de hoy"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/contenedorPendientesHoy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <!-- Item de ejemplo 1 -->
            <LinearLayout
                android:id="@+id/tarjetaPendiente1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comprar leche y pan"
                        android:textSize="16sp"
                        android:textColor="#212121" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08:30 AM"
                        android:textSize="12sp"
                        android:textColor="#757575" />
                </LinearLayout>

                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false" />
            </LinearLayout>

            <!-- Item de ejemplo 2 -->
            <LinearLayout
                android:id="@+id/tarjetaPendiente2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reunión con el equipo"
                        android:textSize="16sp"
                        android:textColor="#212121" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10:00 AM"
                        android:textSize="12sp"
                        android:textColor="#757575" />
                </LinearLayout>

                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- 3. Sección: Próximos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Próximos"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/contenedorProximos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- Item de ejemplo -->
            <LinearLayout
                android:id="@+id/tarjetaProximo1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cita médica control"
                        android:textSize="16sp"
                        android:textColor="#212121" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mañana - 03:00 PM"
                        android:textSize="12sp"
                        android:textColor="#757575" />
                </LinearLayout>

                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- 4. Sección: Resumen numérico -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- Bloque Vencidos -->
            <LinearLayout
                android:id="@+id/tarjetaVencidos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:elevation="4dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vencidos"
                    android:textSize="12sp"
                    android:textColor="#D32F2F"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/textoCantidadVencidos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F" />
            </LinearLayout>

            <!-- Bloque Completados -->
            <LinearLayout
                android:id="@+id/tarjetaCompletados"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:elevation="4dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completados"
                    android:textSize="12sp"
                    android:textColor="#388E3C"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/textoCantidadCompletados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#388E3C" />
            </LinearLayout>
        </LinearLayout>

        <!-- 5. Sección: Accesos rápidos -->
        <Button
            android:id="@+id/botonCrearNuevoRecordatorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crear nuevo recordatorio"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/botonVerTodosRecordatorios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver todos los recordatorios"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/botonIrACalendario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calendario"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/botonIrAConfiguracion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configuración" />

    </LinearLayout>
</ScrollView>
